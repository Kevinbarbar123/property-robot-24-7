TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Facebook Marketplace search (optional). Create the session file once with
# `python3 facebook_login_setup.py` on a machine with a browser, then point
# this at it (e.g. a persistent volume path on Railway). Without it, the
# scan falls back to OLX only.
# FACEBOOK_SESSION_PATH=data/facebook_session_state.json

# Facebook Marketplace location segment used in search URLs. If results look
# wrong, open Marketplace in your own browser, search near Beirut, and copy
# the location segment from the URL into this variable.
# FACEBOOK_MARKETPLACE_LOCATION=beirut
